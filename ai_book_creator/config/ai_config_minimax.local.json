{
  "provider": "minimax",
  "use_openai_client": false,
  "writing_model": "MiniMax-M2.7",
  "review_model": "MiniMax-M2.7",
  "base_url": "https://api.minimax.io/anthropic",
  "api_key_env": "MINIMAX_API_KEY",
  "usage_state_path": "book_output/ai_usage_state.json",
  "timeout": 900,
  "min_book_pages": 300,
  "min_chapter_words": 1000,
  "max_chapter_expansion_attempts": 4
}
