{
  "provider": "google",
  "use_openai_client": false,
  "writing_model": "gemini-3-flash-preview",
  "review_model": "gemini-3-flash-preview",
  "api_key_env": "GOOGLE_API_KEY",
  "usage_state_path": "book_output/ai_usage_state.json",
  "openai_daily_token_limits": {
    "pro": 250000,
    "mini": 2500000
  },
  "min_book_pages": 300,
  "min_chapter_words": 1000,
  "max_chapter_expansion_attempts": 4
}
