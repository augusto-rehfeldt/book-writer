{
  "provider": "openai",
  "use_openai_client": true,
  "writing_model": "gpt-5.4-mini",
  "review_model": "gpt-5.4-mini",
  "base_url": "https://api.openai.com",
  "api_key_env": "OPENAI_API_KEY",
  "usage_state_path": "book_output/ai_usage_state.json",
  "openai_daily_token_limits": {
    "pro": 250000,
    "mini": 2500000
  },
  "timeout": 900,
  "min_book_pages": 300,
  "min_chapter_words": 1000,
  "max_chapter_expansion_attempts": 4
}
